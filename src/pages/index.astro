---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Satvik Sabarad</h1>
			<p>Manufacturing Engineer & AI Enthusiast</p>

			<section>
				<h2>About Me</h2>
				<p>
					I'm a Manufacturing Engineer with a passion for AI and technology. I enjoy exploring how
					intelligent systems can transform the way we design, build, and optimize the world around us.
				</p>
			</section>

			<section>
				<h2>Projects</h2>
				<p>Check out my <a href="/projects">Projects page</a> to see what I've been building.</p>
			</section>

			<section>
				<h2>Get in Touch</h2>
				<ul>
					<li><a href="https://www.linkedin.com/in/satviksabarad/" target="_blank">LinkedIn</a></li>
					<li><a href="https://github.com/SatvikSabarad" target="_blank">GitHub</a></li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const projects = [
  {
    slug: 'aeroconnect',
    title: 'AeroConnect — Inflight Wi-Fi Predictor',
    description: 'Predicts inflight Wi-Fi quality for any flight route. Models satellite coverage, beam handoffs, polar blackout zones, and per-airline quirks on an interactive map.',
    tags: ['JavaScript', 'Mapbox GL', 'Physics Engine'],
  },
  {
    slug: 'gantt',
    title: 'AI Gantt Chart Builder',
    description: 'Chat with Claude to build Gantt charts instantly. Describe your project in plain English and the AI extracts tasks, dates, and dependencies.',
    tags: ['Claude AI', 'Frappe Gantt', 'JavaScript'],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── Name & intro ─────────────────────────── -->
      <section class="intro">
        <div class="intro-top">
          <div class="avatar">SS</div>
          <div>
            <h1>Satvik Sabarad</h1>
            <p class="headline">Where Hardware Meets Intelligence</p>
          </div>
        </div>
        <div class="intro-links">
          <a href="/projects/" class="btn-primary">View Projects →</a>
          <a href="https://www.linkedin.com/in/satviksabarad/" target="_blank" class="btn-ghost">LinkedIn</a>
          <a href="https://github.com/SatvikSabarad" target="_blank" class="btn-ghost">GitHub</a>
        </div>
      </section>

      <!-- ── Two-sided duality ─────────────────────── -->
      <section class="duality">

        <div class="panel panel-hw">
          <div class="panel-header">
            <div class="panel-icon hw-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="26" height="26">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <div>
              <h2 class="panel-title">Hardware at Scale</h2>
              <p class="panel-sub hw-sub">Engineering the physical world — precisely, at volume.</p>
            </div>
          </div>
          <p class="panel-body">
            MIT-trained in manufacturing systems engineering. At Tesla, I developed and scaled
            electromechanical assembly processes across multiple Gigafactories — operating in
            environments where engineering decisions get pressure-tested by production at volume.
            At Amazon Robotics, I ramp sensing and compute modules — the hardware that makes
            robots perceive and think. I've learned that the hardest part of building anything
            isn't the design. It's the disciplined, unglamorous work of making it repeatable.
          </p>
          <ul class="panel-list">
            <li><span class="dot hw-dot"></span>M.S. Manufacturing, MIT</li>
            <li><span class="dot hw-dot"></span>Tesla — Process Development across Gigafactories</li>
            <li><span class="dot hw-dot"></span>Amazon Robotics — Sensing & Compute Module Ramp</li>
            <li><span class="dot hw-dot"></span>Electromechanical Assembly · High-Volume Production</li>
          </ul>
        </div>

        <div class="panel-divider" aria-hidden="true">
          <div class="divider-line"></div>
          <div class="divider-badge">×</div>
          <div class="divider-line"></div>
        </div>

        <div class="panel panel-ai">
          <div class="panel-header">
            <div class="panel-icon ai-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="26" height="26">
                <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <div>
              <h2 class="panel-title">AI as a Force Multiplier</h2>
              <p class="panel-sub ai-sub">Compressing the hardware lifecycle with intelligence.</p>
            </div>
          </div>
          <p class="panel-body">
            Hardware development is full of costly loops — late design changes, opaque supplier
            risk, test coverage gaps, yield surprises. I'm convinced AI can compress all of it.
            I build software tools powered by LLMs to accelerate the hardware lifecycle: from
            design automation and DFM analysis to supply chain intelligence and test optimization.
            The intersection of physical systems and AI isn't a future state — I'm working on it
            right now, and shipping things that prove it.
          </p>
          <ul class="panel-list">
            <li><span class="dot ai-dot"></span>LLMs applied to design, supply chain & testing</li>
            <li><span class="dot ai-dot"></span>AI tooling for hardware DFM & quality prediction</li>
            <li><span class="dot ai-dot"></span>Building & shipping working software projects</li>
            <li><span class="dot ai-dot"></span>Claude API · Agentic workflows · Full-stack AI tools</li>
          </ul>
        </div>

      </section>

      <!-- ── Projects ──────────────────────────────── -->
      <section class="projects-section">
        <h2 class="section-label">Featured Projects</h2>
        <div class="project-grid">
          {projects.map((p) => (
            <a href={`/projects/${p.slug}/`} class="project-card">
              <div class="card-inner">
                <h3>{p.title}</h3>
                <p>{p.description}</p>
                <div class="tags">
                  {p.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
              <span class="arrow">→</span>
            </a>
          ))}
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5em 1.25em 4em;
  }

  /* ── Intro ──────────────────────────────────────── */
  .intro {
    margin-bottom: 2.5em;
    padding-bottom: 2.5em;
    border-bottom: 1px solid var(--border);
  }
  .intro-top {
    display: flex;
    align-items: center;
    gap: 1.25em;
    margin-bottom: 1.25em;
  }
  .avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #06b6d4);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.5px;
  }
  h1 {
    font-size: 1.75rem;
    margin-bottom: 0.1em;
  }
  .headline {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-weight: 500;
    margin: 0;
  }
  .intro-links {
    display: flex;
    gap: 0.65em;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.5em 1.15em;
    background: var(--accent);
    color: #fff !important;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }
  .btn-primary:hover {
    background: var(--accent-dark);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .btn-ghost {
    display: inline-block;
    padding: 0.5em 1.15em;
    border: 1px solid var(--border);
    color: var(--text-muted) !important;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.875rem;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover {
    border-color: var(--text-muted);
    color: var(--text) !important;
    text-decoration: none;
  }

  /* ── Duality ─────────────────────────────────────── */
  .duality {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    margin-bottom: 3em;
    align-items: stretch;
  }

  .panel {
    padding: 1.75em;
    border: 1px solid var(--border);
    background: var(--bg);
    border-radius: 0;
  }
  .panel-hw {
    border-top: 3px solid #6366f1;
    border-radius: var(--radius) 0 0 var(--radius);
  }
  .panel-ai {
    border-top: 3px solid #06b6d4;
    border-radius: 0 var(--radius) var(--radius) 0;
    border-left: none;
  }

  .panel-header {
    display: flex;
    align-items: flex-start;
    gap: 0.9em;
    margin-bottom: 1.1em;
  }
  .panel-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .hw-icon { background: rgba(99, 102, 241, 0.1); color: #6366f1; }
  .ai-icon { background: rgba(6, 182, 212, 0.1); color: #06b6d4; }

  .panel-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.2em;
    letter-spacing: -0.01em;
  }
  .panel-sub {
    font-size: 0.8rem;
    font-weight: 500;
    margin: 0;
    letter-spacing: 0.01em;
  }
  .hw-sub { color: #6366f1; }
  .ai-sub { color: #06b6d4; }

  .panel-body {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1.25em;
  }

  .panel-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }
  .panel-list li {
    font-size: 0.8rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.6em;
    margin: 0;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .hw-dot { background: #6366f1; }
  .ai-dot { background: #06b6d4; }

  /* Divider between panels */
  .panel-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 40px;
    padding: 2em 0;
    background: var(--bg-surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .divider-line {
    flex: 1;
    width: 1px;
    background: var(--border);
  }
  .divider-badge {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-light);
    padding: 0.4em 0;
    line-height: 1;
    user-select: none;
  }

  /* ── Projects ───────────────────────────────────── */
  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1em;
  }
  .project-grid {
    display: flex;
    flex-direction: column;
    gap: 0.65em;
  }
  .project-card {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: 1.15em 1.4em;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    background: var(--bg);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  }
  .project-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 16px rgba(var(--accent-rgb), 0.1);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .card-inner { flex: 1; min-width: 0; }
  .card-inner h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.25em;
    color: var(--text);
  }
  .card-inner p {
    font-size: 0.825rem;
    color: var(--text-muted);
    margin-bottom: 0.65em;
    line-height: 1.5;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 0.3em; }
  .tag {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.18em 0.5em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
  }
  .arrow {
    font-size: 1rem;
    color: var(--text-light);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }
  .project-card:hover .arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  /* ── Mobile ──────────────────────────────────────── */
  @media (max-width: 720px) {
    main { padding: 2em 1em 3em; }
    h1 { font-size: 1.5rem; }

    .duality {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }
    .panel-hw {
      border-radius: var(--radius) var(--radius) 0 0;
      border-top: 3px solid #6366f1;
    }
    .panel-ai {
      border-radius: 0 0 var(--radius) var(--radius);
      border-left: 1px solid var(--border);
      border-top: 3px solid #06b6d4;
    }
    .panel-divider {
      flex-direction: row;
      width: 100%;
      height: 36px;
      padding: 0 1.5em;
      border-top: none;
      border-left: 1px solid var(--border);
      border-right: 1px solid var(--border);
    }
    .divider-line {
      flex: 1;
      height: 1px;
      width: auto;
    }
    .panel { padding: 1.4em; }
  }

  @media (max-width: 480px) {
    .panel-header { flex-wrap: nowrap; }
    .panel-title { font-size: 1rem; }
  }
</style>

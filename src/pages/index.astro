---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const projects = [
  {
    slug: 'aeroconnect',
    title: 'AeroConnect — Inflight Wi-Fi Predictor',
    description: 'Predicts inflight Wi-Fi quality for any flight route. Models satellite coverage, beam handoffs, polar blackout zones, and per-airline quirks on an interactive map.',
    tags: ['JavaScript', 'Mapbox GL', 'Physics Engine'],
  },
  {
    slug: 'gantt',
    title: 'AI Gantt Chart Builder',
    description: 'Chat with Claude to build Gantt charts instantly. Describe your project in plain English and the AI extracts tasks, dates, and dependencies.',
    tags: ['Claude AI', 'Frappe Gantt', 'JavaScript'],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ── Masthead ───────────────────────────────── -->
      <section class="masthead">
        <p class="overline">Manufacturing Engineer &amp; AI Builder</p>
        <h1 class="name">Satvik Sabarad</h1>
        <div class="rule"></div>
      </section>

      <!-- ── Two-column intro ───────────────────────── -->
      <section class="bio-cols">
        <div class="bio-col">
          <p>
            MIT manufacturing engineer. Scaled electromechanical assembly
            across Tesla's Gigafactories, and currently ramp sensing and
            compute modules at Amazon Robotics — the hardware that makes
            robots perceive the world. High-volume, high-stakes, no shortcuts.
          </p>
        </div>
        <div class="col-divider" aria-hidden="true"></div>
        <div class="bio-col">
          <p>
            I love AI. I build tools that accelerate hardware development —
            design, manufacturing, supply chain, testing — and plenty of
            non-hardware tools too, because vibe coding with AI is just
            too good to stop.
          </p>
        </div>
      </section>

      <div class="rule rule-section"></div>

      <!-- ── Links ─────────────────────────────────── -->
      <div class="action-row">
        <a href="/projects/" class="btn-primary">View Projects →</a>
        <a href="https://www.linkedin.com/in/satviksabarad/" target="_blank" class="btn-ghost">LinkedIn</a>
        <a href="https://github.com/SatvikSabarad" target="_blank" class="btn-ghost">GitHub</a>
      </div>

      <div class="rule rule-section"></div>

      <!-- ── Projects ──────────────────────────────── -->
      <section class="projects-section">
        <p class="section-label">Featured Work</p>
        <div class="project-grid">
          {projects.map((p) => (
            <a href={`/projects/${p.slug}/`} class="project-card">
              <div class="card-inner">
                <h3>{p.title}</h3>
                <p>{p.description}</p>
                <div class="tags">
                  {p.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
              <span class="arrow">→</span>
            </a>
          ))}
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 3.5em 1.5em 5em;
  }

  /* ── Masthead ─────────────────────────────────── */
  .masthead {
    margin-bottom: 2em;
  }
  .overline {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.6em;
  }
  .name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--text);
    margin: 0 0 0.6em;
  }
  .rule {
    height: 1px;
    background: var(--text);
    opacity: 0.15;
  }
  .rule-section {
    margin: 2em 0;
    opacity: 0.1;
  }

  /* ── Two-column bio ───────────────────────────── */
  .bio-cols {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 0 2.5em;
    margin: 2em 0;
    align-items: start;
  }
  .bio-col p {
    font-family: 'Inter', sans-serif;
    font-size: 0.975rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin: 0;
  }
  .col-divider {
    background: var(--border);
    align-self: stretch;
  }

  /* ── Action row ───────────────────────────────── */
  .action-row {
    display: flex;
    gap: 0.65em;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.5em 1.15em;
    background: var(--text);
    color: #fff !important;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.1s;
    letter-spacing: 0.01em;
  }
  .btn-primary:hover {
    opacity: 0.8;
    transform: translateY(-1px);
    text-decoration: none;
  }
  .btn-ghost {
    display: inline-block;
    padding: 0.5em 1.15em;
    border: 1px solid var(--border);
    color: var(--text-muted) !important;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.85rem;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-ghost:hover {
    border-color: var(--text-muted);
    color: var(--text) !important;
    text-decoration: none;
  }

  /* ── Projects ─────────────────────────────────── */
  .section-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 1.1em;
  }
  .project-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .project-card {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: 1.15em 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }
  .project-card:first-child { border-top: 1px solid var(--border); }
  .project-card:hover { text-decoration: none; }
  .project-card:hover .arrow { color: var(--accent); transform: translateX(3px); }
  .card-inner { flex: 1; min-width: 0; }
  .card-inner h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.25em;
    color: var(--text);
  }
  .card-inner p {
    font-size: 0.825rem;
    color: var(--text-muted);
    margin: 0 0 0.6em;
    line-height: 1.5;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 0.3em; }
  .tag {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.18em 0.5em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
  }
  .arrow {
    font-size: 1rem;
    color: var(--text-light);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  /* ── Mobile ───────────────────────────────────── */
  @media (max-width: 640px) {
    main { padding: 2.5em 1.25em 4em; }
    .bio-cols {
      grid-template-columns: 1fr;
      gap: 1.5em 0;
    }
    .col-divider { display: none; }
    .bio-col p { font-size: 0.925rem; }
  }
</style>

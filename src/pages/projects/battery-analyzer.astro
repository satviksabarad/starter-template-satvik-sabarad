---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Battery Analyzer | ${SITE_TITLE}`} description="Real-time battery charging session tracker" />
  </head>
  <body>
    <Header />
    <main>
      <div class="breadcrumb"><a href="/projects/">← Projects</a></div>
      <h1>Battery Charging Rate Analyzer</h1>
      <div class="tags">
        <span class="tag">Python</span>
        <span class="tag">HTML</span>
        <span class="tag">Android / Termux</span>
      </div>

      <div class="details">
        <p>
          A real-time battery monitoring tool that runs on Android via Termux. It tracks charging
          sessions — logging start time, initial and final battery levels, and duration — then serves
          everything through a local web dashboard.
        </p>
        <p>
          Uses kernel-level netlink socket events for efficient, event-driven monitoring with a
          polling fallback, so it can run persistently in the background with minimal battery drain.
          Session history is stored in JSON and exposed through a small REST API.
        </p>
        <p>
          The demo below runs in <strong>standalone mode</strong> using your browser's Battery API —
          plug in your device to see it track a live charging session.
        </p>
      </div>

      <div class="app-wrapper">
        <iframe src="/battery-analyzer.html" title="Battery Analyzer" scrolling="yes"></iframe>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 780px;
    margin: 0 auto;
    padding: 2em 1.25em 3em;
  }
  .breadcrumb { margin-bottom: 1em; font-size: 0.875rem; }
  .breadcrumb a { color: var(--accent); font-weight: 500; }
  .breadcrumb a:hover { text-decoration: underline; }
  h1 { margin: 0 0 0.5em; font-size: 1.75rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.35em; margin-bottom: 1.5em; }
  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2em 0.6em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
  }
  .details { margin-bottom: 1.5em; line-height: 1.7; color: var(--text-muted); }
  .details p { margin: 0 0 0.75em; font-size: 0.95rem; }
  .details strong { color: var(--text); }
  .app-wrapper {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  iframe {
    width: 100%;
    height: 720px;
    border: none;
    display: block;
  }
  @media (max-width: 640px) {
    h1 { font-size: 1.4rem; }
    iframe { height: 500px; }
  }
</style>

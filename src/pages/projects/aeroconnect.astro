---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`AeroConnect | ${SITE_TITLE}`} description="Inflight Wi-Fi quality predictor" />
  </head>
  <body>
    <Header />
    <main>
      <div class="breadcrumb"><a href="/projects/">← Projects</a></div>
      <h1>AeroConnect — Inflight Wi-Fi Predictor</h1>
      <div class="tags">
        <span class="tag">JavaScript</span>
        <span class="tag">Mapbox GL</span>
        <span class="tag">Physics Engine</span>
      </div>

      <div class="details">
        <p>
          Predicts inflight Wi-Fi quality and availability for any flight route. Enter a flight number
          (e.g. CX830, UA837) and the app looks up the real route, models satellite beam handoffs,
          polar blackout zones (above 71°N/S), and per-airline provider quirks.
        </p>
        <p>
          The output is an interactive Mapbox map showing the route overlaid with coverage quality,
          plus a Gantt-style timeline breaking the flight into segments: full connectivity, degraded,
          handoff blips, and blackout.
        </p>
      </div>

      <div class="app-wrapper">
        <iframe src="/aeroconnect/index.html" title="AeroConnect Predictor" scrolling="yes"></iframe>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2em 1.25em 3em;
  }
  .breadcrumb { margin-bottom: 1em; font-size: 0.875rem; }
  .breadcrumb a { color: var(--accent); font-weight: 500; }
  .breadcrumb a:hover { text-decoration: underline; }
  h1 { margin: 0 0 0.5em; font-size: 1.75rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.35em; margin-bottom: 1.5em; }
  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2em 0.6em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
  }
  .details { margin-bottom: 1.5em; line-height: 1.7; color: var(--text-muted); }
  .details p { margin: 0 0 0.75em; font-size: 0.95rem; }
  .app-wrapper {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  iframe {
    width: 100%;
    height: 860px;
    border: none;
    display: block;
  }
  @media (max-width: 640px) {
    h1 { font-size: 1.4rem; }
    iframe { height: 600px; }
  }
</style>

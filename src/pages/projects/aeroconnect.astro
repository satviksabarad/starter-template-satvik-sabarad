---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`AeroConnect | ${SITE_TITLE}`} description="Inflight Wi-Fi quality predictor" />
  </head>
  <body>
    <Header />
    <main>
      <div class="breadcrumb"><a href="/projects/">← Projects</a></div>
      <h1>AeroConnect — Inflight Wi-Fi Predictor</h1>
      <div class="tags">
        <span class="tag">JavaScript</span>
        <span class="tag">Mapbox GL</span>
        <span class="tag">Physics Engine</span>
      </div>

      <div class="details">
        <p>
          Predicts inflight Wi-Fi quality and availability for any flight route. Enter a departure
          and arrival airport, select your airline, and the app models the full flight path on a
          great-circle route — flagging satellite beam handoffs, polar blackout zones (above 71°N/S),
          and per-airline provider quirks.
        </p>
        <p>
          The output is an interactive Mapbox map showing the route overlaid with coverage quality,
          plus a Gantt-style timeline breaking the flight into segments: full connectivity, degraded,
          handoff blips, and blackout.
        </p>
      </div>

      <div class="app-wrapper">
        <iframe src="/aeroconnect/index.html" title="AeroConnect Predictor" scrolling="yes"></iframe>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 980px;
    margin: 0 auto;
    padding: 2em 1em 3em;
  }
  .breadcrumb {
    margin-bottom: 1em;
    font-size: 0.9em;
  }
  .breadcrumb a {
    color: var(--accent);
    text-decoration: none;
  }
  .breadcrumb a:hover { text-decoration: underline; }
  h1 { margin: 0 0 0.5em; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.4em; margin-bottom: 1.5em; }
  .tag {
    background: rgb(var(--gray-light));
    border-radius: 4px;
    padding: 0.2em 0.6em;
    font-size: 0.8em;
  }
  .details {
    margin-bottom: 1.5em;
    line-height: 1.7;
  }
  .details p { margin: 0 0 0.8em; }
  .note {
    background: rgb(var(--gray-light));
    border-radius: 8px;
    padding: 0.8em 1em;
    font-size: 0.9em;
    margin-top: 0.5em;
  }
  .note a { color: var(--accent); }
  .app-wrapper {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgb(var(--gray-light));
  }
  iframe {
    width: 100%;
    height: 860px;
    border: none;
    display: block;
  }
</style>

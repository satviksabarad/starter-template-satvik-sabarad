---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`AI Gantt Builder | ${SITE_TITLE}`} description="Chat-driven Gantt chart builder powered by Claude AI" />
  </head>
  <body>
    <Header />
    <main>
      <div class="breadcrumb"><a href="/projects/">← Projects</a></div>
      <h1>AI Gantt Chart Builder</h1>
      <div class="tags">
        <span class="tag">Claude AI</span>
        <span class="tag">Frappe Gantt</span>
        <span class="tag">JavaScript</span>
      </div>

      <div class="details">
        <p>
          A chat-driven Gantt chart builder powered by Claude. Describe your project timeline in plain
          English, paste in a task list, or upload a document — the AI parses it and renders an
          interactive Gantt chart with tasks, durations, and dependencies automatically extracted.
        </p>
        <p>
          You can keep chatting to add tasks, shift dates, adjust dependencies, or reorganize the
          entire chart. Built on <a href="https://frappe.io/gantt" target="_blank">Frappe Gantt</a>
          for the rendering layer.
        </p>
        <div class="note">
          Requires an <strong>Anthropic API key</strong> — click the <strong>⚙ API Key</strong> button
          in the app to add yours. Keys are stored locally in your browser and never sent anywhere
          except the Anthropic API.
        </div>
      </div>

      <div class="video-wrapper">
        <p class="section-label">Demo Video</p>
        <video controls preload="metadata">
          <source src="/gantt/demo.mp4" type="video/mp4" />
        </video>
      </div>

      <div class="app-wrapper">
        <iframe src="/gantt/index.html" title="AI Gantt Chart Builder"></iframe>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2em 1.25em 3em;
  }
  .breadcrumb { margin-bottom: 1em; font-size: 0.875rem; }
  .breadcrumb a { color: var(--accent); font-weight: 500; }
  .breadcrumb a:hover { text-decoration: underline; }
  h1 { margin: 0 0 0.5em; font-size: 1.75rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.35em; margin-bottom: 1.5em; }
  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2em 0.6em;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-muted);
  }
  .details { margin-bottom: 1.5em; line-height: 1.7; color: var(--text-muted); }
  .details p { margin: 0 0 0.75em; font-size: 0.95rem; }
  .details a { color: var(--accent); }
  .note {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.8em 1em;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.5em;
  }
  .note strong { color: var(--text); }
  .section-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-light);
    margin: 0 0 0.6em;
  }
  .video-wrapper { margin-bottom: 1.5em; }
  video {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: block;
    background: #000;
  }
  .app-wrapper {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }
  iframe {
    width: 100%;
    height: 820px;
    border: none;
    display: block;
  }
  @media (max-width: 640px) {
    h1 { font-size: 1.4rem; }
    iframe { height: 600px; }
  }
</style>
